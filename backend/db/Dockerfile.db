# pgvector/pgvector already ships with the vector extension pre-built for the
# declared PostgreSQL version — no manual apt install needed.
# Apache AGE is not used in the current schema (all AGE lines are commented out);
# switch back to AGE base when graph queries are needed.
FROM pgvector/pgvector:pg16

# Enable the extension on first start
RUN echo "CREATE EXTENSION IF NOT EXISTS vector;" \
        > /docker-entrypoint-initdb.d/01_vector.sql
