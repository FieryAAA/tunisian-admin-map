# We use the official Apache AGE image as a base because building AGE from source is complex
FROM apache/age:latest

# Install pgvector from source
RUN apt-get update && apt-get install -y --no-install-recommends \
    postgresql-server-dev-16 \
    git \
    make \
    gcc \
    libc-dev \
    && cd /tmp \
    && git clone --branch v0.7.0 https://github.com/pgvector/pgvector.git \
    && cd pgvector \
    && make \
    && make install \
    && rm -rf /tmp/pgvector \
    && apt-get remove -y git make gcc postgresql-server-dev-16 \
    && apt-get autoremove -y \
    && rm -rf /var/lib/apt/lists/*

# Add initialization script to enable extensions
RUN echo "CREATE EXTENSION IF NOT EXISTS vector;" > /docker-entrypoint-initdb.d/01_vector.sql \
    && echo "CREATE EXTENSION IF NOT EXISTS age;" > /docker-entrypoint-initdb.d/02_age.sql

# Note: The base apache/age image handles the AGE setup.
# pgvector is added on top.
